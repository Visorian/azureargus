NUXT_PUBLIC_ALLOW_ANONYMOUS_MODE=true
NUXT_PUBLIC_DEFAULT_LOOKBACK_MINUTES=15
NUXT_OIDC_PROVIDERS_ENTRA_CLIENT_ID=
NUXT_OIDC_PROVIDERS_ENTRA_CLIENT_SECRET=
NUXT_OIDC_PROVIDERS_ENTRA_REDIRECT_URI=http://localhost:3000/auth/entra/callback
NUXT_OIDC_PROVIDERS_ENTRA_AUTHORIZATION_URL=https://login.microsoftonline.com/TENANT_ID/oauth2/v2.0/authorize
NUXT_OIDC_PROVIDERS_ENTRA_TOKEN_URL=https://login.microsoftonline.com/TENANT_ID/oauth2/v2.0/token
NUXT_OIDC_PROVIDERS_ENTRA_LOGOUT_URL=https://login.microsoftonline.com/TENANT_ID/oauth2/v2.0/logout
NUXT_OIDC_SESSION_SECRET=
NUXT_OIDC_AUTH_SESSION_SECRET=
NUXT_OIDC_TOKEN_KEY=

NUXT_LOG_ANALYTICS_TENANT_ID=
NUXT_LOG_ANALYTICS_CLIENT_ID=
NUXT_LOG_ANALYTICS_CLIENT_SECRET=
NUXT_LOG_ANALYTICS_WORKSPACE_ID=

# Optional override for deployment-mounted country MMDB.
NUXT_IP_COUNTRY_DATABASE_PATH=.data/dbip-country-lite.mmdb

# Version shown in the sidebar footer. Release/deployment can set this.
