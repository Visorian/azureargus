{
  "name": "azure-argus",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --host 127.0.0.1",
    "build": "nuxt build",
    "geoip:update": "bun scripts/update-ip-country-database.ts",
    "preview": "nuxt preview",
    "lint": "oxlint app server shared tests nuxt.config.ts vitest.config.ts playwright.config.ts",
    "fmt": "oxfmt .",
    "typecheck": "nuxt typecheck",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "bump": "bunx taze major --maturity-period -w",
    "release": "bunx changelogen --release --push",
    "prepare": "if command -v git >/dev/null 2>&1; then lefthook install; fi"
  },
  "dependencies": {
    "@azure/event-hubs": "^6.0.4",
    "@maxmind/geoip2-node": "7.0.0",
    "@nuxt/ui": "^4.9.0",
    "buffer": "^6.0.3",
    "nuxt": "^4.4.8",
    "nuxt-oidc-auth": "^1.0.0-beta.11",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.39",
    "vue-virtual-scroller": "^3.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@iconify-json/lucide": "^1.2.116",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "overrides": {
    "vite": "^8.1.3"
  },
  "packageManager": "bun@1.3.14"
}
